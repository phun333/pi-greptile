    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "extension",
    "greptile",
    "code-review",
    "ai-code-review",
    "pull-request",
    "mcp"
  ],
  "license": "MIT",
  "author": "Ali (https://github.com/phun333)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phun333/pi-greptile.git"
  },
  "bugs": {
    "url": "https://github.com/phun333/pi-greptile/issues"
  },
  "homepage": "https://github.com/phun333/pi-greptile#readme",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/phun333/pi-greptile/main/banner.png"
  },
